# Supabase (server-side only — use service role key for chat API + rate limiting)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Rate limiting — random 32+ character string; set in Vercel env vars for production
RATE_LIMIT_SALT=change-me-to-a-long-random-string
